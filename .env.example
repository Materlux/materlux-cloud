# ===== Materlux Cloud — copie para .env e preencha (NÃO versione o .env) =====

# Banco Postgres gerenciado (Supabase/Neon). Use a "connection string" (URI).
DATABASE_URL=postgresql://usuario:senha@host:5432/postgres

# Segredo da sessão — gere um valor aleatório longo.
JWT_SECRET=troque-por-um-valor-aleatorio-bem-longo
COOKIE_SECURE=true
SESSION_HOURS=12

# Agente (Google Gemini)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# WhatsApp: zapi | meta | console (console = só teste interno, não envia)
WA_PROVIDER=zapi
WA_VERIFY_TOKEN=materlux-verify
# Z-API
ZAPI_INSTANCE=
ZAPI_TOKEN=
ZAPI_CLIENT_TOKEN=
# Meta Cloud API (alternativa oficial)
META_TOKEN=
META_PHONE_ID=

# Agenda
SLOT_MINUTES=30
CLINIC_TZ=America/Sao_Paulo
BOOKABLE_PROFESSIONAL_IDS=1,4,12

# Backup (script backup_to_gcs.py)
GCS_BUCKET=postgres-materlux-backups
GOOGLE_APPLICATION_CREDENTIALS=/caminho/para/service-account.json
# URL de alerta (opcional) para avisar se o backup falhar (ex.: webhook do WhatsApp/Slack)
BACKUP_ALERT_WEBHOOK=
